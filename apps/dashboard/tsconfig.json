{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false
  },
  "comment": "vite.config.ts NO se incluye: usa `process` (node) y vite ya lo ejecuta solo; tsc solo chequea app + functions (que usan APIs web, no node).",
  "include": ["src", "functions"]
}
