{
  "name": "@l5a/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen": "node scripts/gen.mjs",
    "predev": "npm run gen",
    "dev": "vite",
    "prebuild": "npm run gen",
    "build": "tsc --noEmit && vite build",
    "typecheck": "npm run gen && tsc --noEmit",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "wrangler": "^3.95.0"
  }
}
